#include <mega16.h>
#include <delay.h>
#include "pwm.h"
#include "config.h"

void main(void)
{
    unsigned char i;
    SystemInit();
    SetPWMFrequency(600);  
    
    while (1)
    {      
        if(PIND.0 == 0)
        {
            for(i = 0; i < 80; i++)
            {
                SetPWMFrequency(600 + i*10);
                delay_ms(20);
            }
        }                 
        if(PIND.1 == 0)
        {
            for(i = 0; i < 80; i++)
            {
                SetPWMFrequency(1400 - i*10);
                delay_ms(20);
            }
        }
               
        //SystemUpdate();
    }
}

#include <mega16.h>
#include <stdio.h>
#include "config.h"


void main(void)
{
    SystemInit(); 
    
    UCSRA=0x00;
    UCSRB=0x08;
    UCSRC=0x86;
    UBRRH=0x00;
    UBRRL=0x2F;
    
    
    printf("%d", SystemGetState());
        
    while (1)
    {                  
        SystemUpdate();
        printf("%d", SystemGetState());
        if(PIND.2 == 0)
        {                                                                   
            SystemSetState(ST_MOTION);
        }
        if(PIND.3 == 0)
        {
            SystemSetState(ST_FLAME);                                                                                                             
        }
    }
}

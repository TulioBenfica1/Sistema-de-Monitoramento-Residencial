#include <mega16.h>
#include "config.h"

void main(void)
{
    SystemInit();
        
    while (1)
    {
        SystemUpdate();
        if(PINB.0 == 0)
        {
            SystemSetState(ST_MOTION);
        }
        if(PINB.1 == 0)
        {
            SystemSetState(ST_SMOKE);                                                                                                             
        }
    }
}

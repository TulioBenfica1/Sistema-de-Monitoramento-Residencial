static SystemState current_state;
static bit lcd_update_pending = 1;
static bit keypad_entry = 0;
static bit read_sensors_flag = 0;
static SystemState past_state;


void SystemInit(void)
{
    // Configuração de registradores 
    LCDInit();
    RTCInit();   
    USARTInit();
    KEYPADInit();
    TIMER1Init();
    SENSORSInit();
    PWMInit();
    #asm
        .equ __i2c_port=0x18
        .equ __sda_bit=3
        .equ __scl_bit=4
    #endasm
    i2c_init();
    #asm("sei");
    
}

void SystemUpdate(void)
{
    if (lcd_update_pending)
    {
        LCDUpdate(current_state);
        if(current_state == ST_BOOT)
        {            
            delay_ms(5000);
            SystemSetState(ST_SET_DATA); 
            return;   
        }
          
        lcd_update_pending = 0;
    }
    if(keypad_entry)
    {
        KEYPADProcess(current_state);
    } 
    if (read_sensors_flag)
    {
        //SensorsUpdate();
    }    
    //BuzzerUpdate(current_state); 
}

void SystemSetState(SystemState state)
{
    past_state = current_state;
    current_state = state;
    if (current_state != ST_SET_DATA && current_state != ST_BOOT){
          SystemCheckState();
    }
    lcd_update_pending = 1;
    if (state == ST_SHOCK || state == ST_MOTION || 
        state == ST_FLAME || state == ST_OVERHEAT || 
        state == ST_DISARMED || state == ST_INVASION)
    {
        keypad_entry = 1;
        PasswordStart();
        DataStart();
    }
    else if (state == ST_SET_DATA)
    {
        keypad_entry = 1;
        DataStart();
        PasswordStart();    
    }
    else
    {
        keypad_entry = 0;
    }
    
    if(state == ST_ARMING_DELAY)
    {
        //delay_ms(60000);         // tempo para ajuste de sensores
        delay_ms(2000);
        current_state = ST_ARMED;
        printf("timestamp,estado do sistema\r\n");
        read_sensors_flag = 1;
    }
}

SystemState SystemGetState(void)
{
    return current_state;
}

void SystemCheckState(){
    if (past_state != current_state){
        SerialUpdate();    
    }  
}

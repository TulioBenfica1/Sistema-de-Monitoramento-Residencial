#include <mega16.h>
#include <stdio.h>
#include <stdlib.h>
#include "usart.h"
#include "config.h"
#include "rtc.h"

void USARTInit(void)
{
    UCSRA=0x00;
    UCSRB=0x08;
    UCSRC=0x86;
    UBRRH=0x00;
    UBRRL=0x2F;
}

void SerialUpdate(void){
    unsigned char *ptr;
    SystemState state;
    ptr = GetRTC(); 
    state = SystemGetState();
    printf("\r%d/%d/%d %d:%d:%d,%d,\n", *(ptr+2), *(ptr+1), *(ptr), *(ptr+3), *(ptr+4), *(ptr+5), state);
    free(ptr);
}
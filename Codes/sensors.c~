#include <mega16.h>
#include <stdio.h>
#include "sensors.h"

bit flag_motion = 0;
static unsigned char flame; 
static unsigned char shock;  
static unsigned char motion;


void SENSORSInit(void) {
    DDRB |= 0x00; // Configura PORTB como entrada
    PORTB |= 0x80;
    GICR |= 0b01000000;
    MCUCR |= 0b00001100;   
}


interrupt [EXT_INT1] void int_ext1_motion (void)
{
    flag_motion = 1;
}

void SensorsUpdate(void) {
    flame = PINB.6; 
    shock = ~PINB.7;
    motion = PINB.5;
    
    printf("valor lido: %d\r\n", flame); 

    if (flame && motion && shock){
        SystemSetState(ST_FLAME);
    }
    else if (flame) {
        SystemSetState(ST_FLAME);
    }
    else if (motion && shock){
        SystemSetState(ST_INVASION);
    }
    else if (shock) {
        SystemSetState(ST_SHOCK);
    }
    else if (motion) {
        SystemSetState(ST_MOTION);
    }
    flag_motion = 0;
    return;
}

